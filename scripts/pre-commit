#!/bin/bash
# Pre-commit hook for Flutty
# Install via scripts/setup.sh or copy into "$(git rev-parse --git-path hooks)".

set -euo pipefail

echo 'Running pre-commit checks...'

staged_dart_files=()
while IFS= read -r file; do
    staged_dart_files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACM -- '*.dart')

if [ "${#staged_dart_files[@]}" -eq 0 ]; then
    echo 'No staged Dart files; skipping Dart checks.'
    echo 'Pre-commit checks passed!'
    exit 0
fi

echo 'Checking formatting...'
dart format --output=none --set-exit-if-changed "${staged_dart_files[@]}"

echo 'Running analyzer on staged Dart files...'
flutter analyze --fatal-infos --no-pub "${staged_dart_files[@]}"

echo 'Skipping tests in pre-commit; full checks run in pre-push.'
echo 'Pre-commit checks passed!'
