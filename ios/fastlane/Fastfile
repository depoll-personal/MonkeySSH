default_platform(:ios)

require 'fileutils'

platform :ios do
  before_all do
    setup_ci if ENV['CI']
  end

  APP_IDS = {
    'Private' => 'xyz.depollsoft.monkeyssh.private',
    'Production' => 'xyz.depollsoft.monkeyssh',
  }.freeze

  LIVE_ACTIVITY_APP_IDS = {
    'Private' => 'xyz.depollsoft.monkeyssh.private.ConnectionStatusLiveActivity',
    'Production' => 'xyz.depollsoft.monkeyssh.ConnectionStatusLiveActivity',
  }.freeze

  METADATA_DIRS = {
    'xyz.depollsoft.monkeyssh.private' => './fastlane/metadata-private',
    'xyz.depollsoft.monkeyssh' => './fastlane/metadata-production',
  }.freeze

  TEAM_ID = '43AWMS3YJX'.freeze

  private_lane :get_api_key do
    app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_API_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_API_ISSUER_ID'],
      key_content: ENV['APP_STORE_CONNECT_API_KEY_CONTENT'],
      is_key_content_base64: false,
    )
  end

  desc 'Sync certificates and profiles for a given type and app identifier'
  private_lane :sync_certs do |options|
    app_id = options[:app_identifier]
    match_type = options[:type] || 'appstore'
    readonly = options.key?(:readonly) ? options[:readonly] : true

    api_key = get_api_key

    match(
      type: match_type,
      app_identifier: app_id,
      api_key: api_key,
      readonly: readonly,
    )
  end

  private_lane :build_and_sign do |options|
    scheme = options[:scheme]
    app_id = APP_IDS[scheme]
    live_activity_app_id = LIVE_ACTIVITY_APP_IDS[scheme]

    sync_certs(
      app_identifier: [app_id, live_activity_app_id],
      type: 'appstore',
      readonly: false,
    )

    profile_name = ENV["sigh_#{app_id}_appstore_profile-name"] ||
                   ENV["sigh_#{app_id}_appstore_profile_name"] ||
                   "match AppStore #{app_id}"
    live_activity_profile_name =
      ENV["sigh_#{live_activity_app_id}_appstore_profile-name"] ||
      ENV["sigh_#{live_activity_app_id}_appstore_profile_name"] ||
      "match AppStore #{live_activity_app_id}"

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: TEAM_ID,
      code_sign_identity: 'Apple Distribution',
      profile_name: profile_name,
      bundle_identifier: app_id,
      path: 'Runner.xcodeproj',
      targets: ['Runner'],
      build_configurations: ["Release-#{scheme}"],
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: TEAM_ID,
      code_sign_identity: 'Apple Distribution',
      profile_name: live_activity_profile_name,
      bundle_identifier: live_activity_app_id,
      path: 'Runner.xcodeproj',
      targets: ['ConnectionStatusLiveActivityExtension'],
      build_configurations: ["Release-#{scheme}"],
    )

    build_app(
      workspace: 'Runner.xcworkspace',
      scheme: scheme,
      configuration: "Release-#{scheme}",
      export_method: 'app-store',
      output_directory: '../build/ios/ipa',
      archive_path: '../build/ios/archive/Runner.xcarchive',
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID}",
    )
  end

  private_lane :resolved_ipa_path do |options|
    provided_ipa_path = options[:ipa_path].to_s
    return provided_ipa_path unless provided_ipa_path.empty?

    lane_context[SharedValues::IPA_OUTPUT_PATH]
  end

  private_lane :resolved_profile_path do |options|
    app_id = options[:app_identifier]
    profile_path = ENV["sigh_#{app_id}_appstore_profile-path"] ||
                   ENV["sigh_#{app_id}_appstore_profile_path"]

    UI.user_error!("Missing installed provisioning profile path for #{app_id}") if profile_path.to_s.empty?
    UI.user_error!("Provisioning profile not found at #{profile_path} for #{app_id}") unless File.exist?(profile_path)

    profile_path
  end

  desc 'Setup code signing for CI builds'
  lane :setup_signing do |options|
    app_id = options[:app_identifier] || 'xyz.depollsoft.monkeyssh.private'
    sync_certs(app_identifier: app_id, type: 'appstore')
  end

  desc 'Build and sign an IPA without uploading it'
  lane :build_ipa do |options|
    scheme = options[:scheme] || 'Private'
    build_and_sign(scheme: scheme)
  end

  desc 'Re-sign an existing IPA for App Store Connect upload'
  lane :resign_ipa do |options|
    scheme = options[:scheme] || 'Private'
    unsigned_ipa_path = options[:unsigned_ipa_path].to_s
    output_ipa_path = options[:output_ipa_path].to_s
    app_id = APP_IDS[scheme]
    live_activity_app_id = LIVE_ACTIVITY_APP_IDS[scheme]

    UI.user_error!('unsigned_ipa_path is required') if unsigned_ipa_path.empty?

    sync_certs(
      app_identifier: [app_id, live_activity_app_id],
      type: 'appstore',
      readonly: false,
    )

    resigned_ipa_path = unsigned_ipa_path
    unless output_ipa_path.empty?
      FileUtils.mkdir_p(File.dirname(output_ipa_path))
      FileUtils.cp(unsigned_ipa_path, output_ipa_path)
      resigned_ipa_path = output_ipa_path
    end

    resign(
      ipa: resigned_ipa_path,
      signing_identity: 'Apple Distribution',
      provisioning_profile: {
        app_id => resolved_profile_path(app_identifier: app_id),
        live_activity_app_id => resolved_profile_path(app_identifier: live_activity_app_id),
      },
      use_app_entitlements: true,
    )

    resigned_ipa_path
  end

  desc 'Build, sign, and upload to TestFlight'
  lane :beta do |options|
    scheme = options[:scheme] || 'Private'
    app_id = APP_IDS[scheme]
    skip_meta = options[:skip_metadata].to_s == 'true'
    provided_ipa_path = options[:ipa_path].to_s

    build_and_sign(scheme: scheme) if provided_ipa_path.empty?

    pilot(
      api_key: get_api_key,
      app_identifier: app_id,
      ipa: resolved_ipa_path(ipa_path: provided_ipa_path),
      skip_waiting_for_build_processing: false,
      skip_submission: false,
      distribute_external: false,
      uses_non_exempt_encryption: false,
    )

    sync_metadata(app_identifier: app_id) unless skip_meta
  end

  desc 'Build, sign, and upload to App Store'
  lane :release do |options|
    scheme = options[:scheme] || 'Production'
    app_id = APP_IDS[scheme]
    skip_meta = options[:skip_metadata].to_s == 'true'
    provided_ipa_path = options[:ipa_path].to_s

    build_and_sign(scheme: scheme) if provided_ipa_path.empty?

    deliver(
      api_key: get_api_key,
      app_identifier: app_id,
      ipa: resolved_ipa_path(ipa_path: provided_ipa_path),
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
    )

    sync_metadata(app_identifier: app_id) unless skip_meta
  end

  desc 'Sync metadata and app icon to App Store Connect (no build required)'
  lane :sync_metadata do |options|
    app_id = options[:app_identifier] || 'xyz.depollsoft.monkeyssh'
    meta_path = METADATA_DIRS[app_id] || './fastlane/metadata-production'

    begin
      deliver(
        api_key: get_api_key,
        app_identifier: app_id,
        metadata_path: meta_path,
        skip_binary_upload: true,
        skip_screenshots: true,
        submit_for_review: false,
        automatic_release: false,
        force: true,
      )
    rescue StandardError => e
      if e.message.include?('No data')
        UI.important('Review detail not found (expected for first version). Metadata was still uploaded.')
      else
        raise e
      end
    end
  end
end
