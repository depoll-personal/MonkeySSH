default_platform(:ios)

require 'fileutils'
require 'shellwords'
require 'tmpdir'

platform :ios do
  before_all do
    setup_ci if ENV['CI']
  end

  APP_IDS = {
    'Private' => 'xyz.depollsoft.monkeyssh.private',
    'Production' => 'xyz.depollsoft.monkeyssh',
  }.freeze

  LIVE_ACTIVITY_APP_IDS = {
    'Private' => 'xyz.depollsoft.monkeyssh.private.ConnectionStatusLiveActivity',
    'Production' => 'xyz.depollsoft.monkeyssh.ConnectionStatusLiveActivity',
  }.freeze

  METADATA_DIRS = {
    'xyz.depollsoft.monkeyssh.private' => './fastlane/metadata-private',
    'xyz.depollsoft.monkeyssh' => './fastlane/metadata-production',
  }.freeze

  TEAM_ID = '43AWMS3YJX'.freeze

  private_lane :get_api_key do
    app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_API_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_API_ISSUER_ID'],
      key_content: ENV['APP_STORE_CONNECT_API_KEY_CONTENT'],
      is_key_content_base64: false,
    )
  end

  desc 'Sync certificates and profiles for a given type and app identifier'
  private_lane :sync_certs do |options|
    app_id = options[:app_identifier]
    match_type = options[:type] || 'appstore'
    readonly = options.key?(:readonly) ? options[:readonly] : true

    api_key = get_api_key

    match(
      type: match_type,
      app_identifier: app_id,
      api_key: api_key,
      readonly: readonly,
    )
  end

  private_lane :build_and_sign do |options|
    scheme = options[:scheme]
    app_id = APP_IDS[scheme]
    live_activity_app_id = LIVE_ACTIVITY_APP_IDS[scheme]

    sync_certs(
      app_identifier: [app_id, live_activity_app_id],
      type: 'appstore',
      readonly: false,
    )

    profile_name = ENV["sigh_#{app_id}_appstore_profile-name"] ||
                   ENV["sigh_#{app_id}_appstore_profile_name"] ||
                   "match AppStore #{app_id}"
    live_activity_profile_name =
      ENV["sigh_#{live_activity_app_id}_appstore_profile-name"] ||
      ENV["sigh_#{live_activity_app_id}_appstore_profile_name"] ||
      "match AppStore #{live_activity_app_id}"

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: TEAM_ID,
      code_sign_identity: 'Apple Distribution',
      profile_name: profile_name,
      bundle_identifier: app_id,
      path: 'Runner.xcodeproj',
      targets: ['Runner'],
      build_configurations: ["Release-#{scheme}"],
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: TEAM_ID,
      code_sign_identity: 'Apple Distribution',
      profile_name: live_activity_profile_name,
      bundle_identifier: live_activity_app_id,
      path: 'Runner.xcodeproj',
      targets: ['ConnectionStatusLiveActivityExtension'],
      build_configurations: ["Release-#{scheme}"],
    )

    build_app(
      workspace: 'Runner.xcworkspace',
      scheme: scheme,
      configuration: "Release-#{scheme}",
      export_method: 'app-store',
      output_directory: '../build/ios/ipa',
      archive_path: '../build/ios/archive/Runner.xcarchive',
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID}",
    )
  end

  private_lane :resolved_ipa_path do |options|
    provided_ipa_path = options[:ipa_path].to_s
    provided_ipa_path.empty? ? lane_context[SharedValues::IPA_OUTPUT_PATH] : provided_ipa_path
  end

  private_lane :resolved_profile_path do |options|
    app_id = options[:app_identifier]
    profile_path = ENV["sigh_#{app_id}_appstore_profile-path"] ||
                   ENV["sigh_#{app_id}_appstore_profile_path"]

    UI.user_error!("Missing installed provisioning profile path for #{app_id}") if profile_path.to_s.empty?
    UI.user_error!("Provisioning profile not found at #{profile_path} for #{app_id}") unless File.exist?(profile_path)

    profile_path
  end

  private_lane :resolved_certificate_name do |options|
    app_id = options[:app_identifier]
    certificate_name = ENV["sigh_#{app_id}_appstore_certificate-name"] ||
                       ENV["sigh_#{app_id}_appstore_certificate_name"]

    UI.user_error!("Missing installed certificate name for #{app_id}") if certificate_name.to_s.empty?

    certificate_name
  end

  private_lane :extract_profile_entitlements do |options|
    profile_path = options[:profile_path]
    output_path = options[:output_path]

    sh(
      "security cms -D -i #{profile_path.shellescape} | " \
      "plutil -extract Entitlements xml1 -o #{output_path.shellescape} -",
    )

    output_path
  end

  private_lane :bundle_executable_path do |options|
    bundle_path = options[:bundle_path]
    info_plist_path = File.join(bundle_path, 'Info.plist')
    UI.user_error!("Info.plist not found at #{info_plist_path}") unless File.exist?(info_plist_path)

    executable_name = sh(
      "/usr/libexec/PlistBuddy -c 'Print :CFBundleExecutable' #{info_plist_path.shellescape}",
      log: false,
    ).strip
    executable_path = File.join(bundle_path, executable_name)
    UI.user_error!("Bundle executable not found at #{executable_path}") unless File.exist?(executable_path)

    executable_path
  end

  private_lane :embed_swift_runtime do |options|
    bundle_path = options[:bundle_path]
    frameworks_path = File.join(bundle_path, 'Frameworks')
    FileUtils.mkdir_p(frameworks_path)

    command = [
      'xcrun',
      'swift-stdlib-tool',
      '--copy',
      '--platform',
      'iphoneos',
      '--destination',
      frameworks_path,
      '--scan-executable',
      bundle_executable_path(bundle_path: bundle_path),
      '--scan-folder',
      frameworks_path,
    ]
    sh(command.map(&:shellescape).join(' '))
  end

  private_lane :populate_swift_support do |options|
    app_path = options[:app_path]
    package_root = options[:package_root]
    swift_support_dir = File.join(package_root, 'SwiftSupport', 'iphoneos')
    appex_paths = Dir[File.join(app_path, 'PlugIns', '*.appex')].sort

    embed_swift_runtime(bundle_path: app_path)
    appex_paths.each do |appex_path|
      FileUtils.rm_rf(File.join(appex_path, 'Frameworks'))
    end

    FileUtils.rm_rf(File.join(package_root, 'SwiftSupport'))
    FileUtils.mkdir_p(swift_support_dir)

    swift_runtime_paths = Dir[File.join(app_path, 'Frameworks', 'libswift*.dylib')].sort

    swift_runtime_paths
      .uniq { |path| File.basename(path) }
      .each do |runtime_path|
        FileUtils.cp(runtime_path, File.join(swift_support_dir, File.basename(runtime_path)))
      end

    unless Dir.glob(File.join(swift_support_dir, '*')).any?
      UI.message('No Swift runtime libraries detected; removing empty SwiftSupport directory.')
      FileUtils.rm_rf(File.join(package_root, 'SwiftSupport'))
    end
  end

  private_lane :codesign_path do |options|
    path = options[:path]
    signing_identity = options[:signing_identity]
    entitlements_path = options[:entitlements_path].to_s

    command = [
      'codesign',
      '--force',
      '--sign', signing_identity,
      '--timestamp=none',
      '--generate-entitlement-der',
    ]
    command += ['--entitlements', entitlements_path] unless entitlements_path.empty?
    command << path

    sh(command.map(&:shellescape).join(' '))
  end

  desc 'Setup code signing for CI builds'
  lane :setup_signing do |options|
    app_id = options[:app_identifier] || 'xyz.depollsoft.monkeyssh.private'
    sync_certs(app_identifier: app_id, type: 'appstore')
  end

  desc 'Build and sign an IPA without uploading it'
  lane :build_ipa do |options|
    scheme = options[:scheme] || 'Private'
    build_and_sign(scheme: scheme)
  end

  desc 'Re-sign an existing IPA for App Store Connect upload'
  lane :resign_ipa do |options|
    scheme = options[:scheme] || 'Private'
    unsigned_ipa_path = options[:unsigned_ipa_path].to_s
    output_ipa_path = options[:output_ipa_path].to_s
    supported_schemes = (APP_IDS.keys + LIVE_ACTIVITY_APP_IDS.keys).uniq
    unless APP_IDS.key?(scheme) && LIVE_ACTIVITY_APP_IDS.key?(scheme)
      UI.user_error!("Unknown scheme '#{scheme}'. Supported schemes: #{supported_schemes.join(', ')}")
    end
    app_id = APP_IDS[scheme]
    live_activity_app_id = LIVE_ACTIVITY_APP_IDS[scheme]

    UI.user_error!('unsigned_ipa_path is required') if unsigned_ipa_path.empty?
    UI.user_error!("IPA not found at #{unsigned_ipa_path}") unless File.exist?(unsigned_ipa_path)

    sync_certs(
      app_identifier: [app_id, live_activity_app_id],
      type: 'appstore',
      readonly: false,
    )

    resigned_ipa_path = unsigned_ipa_path
    unless output_ipa_path.empty?
      FileUtils.mkdir_p(File.dirname(output_ipa_path))
      FileUtils.cp(unsigned_ipa_path, output_ipa_path)
      resigned_ipa_path = output_ipa_path
    end

    signing_identity = resolved_certificate_name(app_identifier: app_id)
    app_profile_path = resolved_profile_path(app_identifier: app_id)
    live_activity_profile_path = resolved_profile_path(app_identifier: live_activity_app_id)

    Dir.mktmpdir('flutty-resign-ipa') do |tmpdir|
      sh("unzip -q #{resigned_ipa_path.shellescape} -d #{tmpdir.shellescape}")

      payload_dir = File.join(tmpdir, 'Payload')
      app_path = Dir[File.join(payload_dir, '*.app')].first
      UI.user_error!("Expected exactly one .app in #{payload_dir}") if app_path.to_s.empty?

      live_activity_path = Dir[File.join(app_path, 'PlugIns', '*.appex')].first
      UI.user_error!("Expected a live activity extension in #{app_path}/PlugIns") if live_activity_path.to_s.empty?

      app_entitlements_path = File.join(tmpdir, 'app-entitlements.plist')
      live_activity_entitlements_path = File.join(tmpdir, 'live-activity-entitlements.plist')

      extract_profile_entitlements(
        profile_path: app_profile_path,
        output_path: app_entitlements_path,
      )
      extract_profile_entitlements(
        profile_path: live_activity_profile_path,
        output_path: live_activity_entitlements_path,
      )

      FileUtils.cp(app_profile_path, File.join(app_path, 'embedded.mobileprovision'))
      FileUtils.cp(live_activity_profile_path, File.join(live_activity_path, 'embedded.mobileprovision'))

      populate_swift_support(
        app_path: app_path,
        package_root: tmpdir,
      )

      codesign_path(
        path: live_activity_path,
        signing_identity: signing_identity,
        entitlements_path: live_activity_entitlements_path,
      )

      Dir[File.join(app_path, 'Frameworks', '*.framework')].sort.each do |framework_path|
        codesign_path(path: framework_path, signing_identity: signing_identity)
      end
      Dir[File.join(app_path, 'Frameworks', '*.dylib')].sort.each do |dylib_path|
        codesign_path(path: dylib_path, signing_identity: signing_identity)
      end
      codesign_path(
        path: app_path,
        signing_identity: signing_identity,
        entitlements_path: app_entitlements_path,
      )

      FileUtils.rm_f(resigned_ipa_path)
      Dir.chdir(tmpdir) do
        package_entries = Dir.children('.').select do |entry|
          File.directory?(entry) && entry != '__MACOSX'
        end
        UI.user_error!('Expected IPA contents to include Payload') unless package_entries.include?('Payload')
        sh("zip -qry #{resigned_ipa_path.shellescape} #{package_entries.map(&:shellescape).join(' ')}")
      end
    end

    resigned_ipa_path
  end

  desc 'Build, sign, and upload to TestFlight'
  lane :beta do |options|
    scheme = options[:scheme] || 'Private'
    app_id = APP_IDS[scheme]
    skip_meta = options[:skip_metadata].to_s == 'true'
    provided_ipa_path = options[:ipa_path].to_s

    build_and_sign(scheme: scheme) if provided_ipa_path.empty?

    pilot(
      api_key: get_api_key,
      app_identifier: app_id,
      ipa: resolved_ipa_path(ipa_path: provided_ipa_path),
      skip_waiting_for_build_processing: false,
      skip_submission: false,
      distribute_external: false,
      uses_non_exempt_encryption: false,
    )

    sync_metadata(app_identifier: app_id) unless skip_meta
  end

  desc 'Build, sign, and upload to App Store'
  lane :release do |options|
    scheme = options[:scheme] || 'Production'
    app_id = APP_IDS[scheme]
    skip_meta = options[:skip_metadata].to_s == 'true'
    provided_ipa_path = options[:ipa_path].to_s

    build_and_sign(scheme: scheme) if provided_ipa_path.empty?

    deliver(
      api_key: get_api_key,
      app_identifier: app_id,
      ipa: resolved_ipa_path(ipa_path: provided_ipa_path),
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
    )

    sync_metadata(app_identifier: app_id) unless skip_meta
  end

  desc 'Sync metadata and app icon to App Store Connect (no build required)'
  lane :sync_metadata do |options|
    app_id = options[:app_identifier] || 'xyz.depollsoft.monkeyssh'
    meta_path = METADATA_DIRS[app_id] || './fastlane/metadata-production'

    begin
      deliver(
        api_key: get_api_key,
        app_identifier: app_id,
        metadata_path: meta_path,
        skip_binary_upload: true,
        skip_screenshots: true,
        submit_for_review: false,
        automatic_release: false,
        force: true,
      )
    rescue StandardError => e
      if e.message.include?('No data')
        UI.important('Review detail not found (expected for first version). Metadata was still uploaded.')
      else
        raise e
      end
    end
  end
end
