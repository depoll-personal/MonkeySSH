platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
    if target.name == 'sqlite3'
      target.build_configurations.each do |config|
        # Suppress all warnings from upstream sqlite3 C code
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
      end
    end
  end

  main_project = installer.aggregate_targets.first.user_project
  runner_target = main_project.targets.find { |target| target.name == 'Runner' }

  if runner_target
    phase_name = 'Setup LiteRT-LM Desktop'
    existing_phase = runner_target.shell_script_build_phases.find { |phase| phase.name == phase_name }
    phase = existing_phase || runner_target.new_shell_script_build_phase(phase_name)
    phase.shell_script = <<-SCRIPT
PLUGIN_PATH="${PODS_ROOT}/../Flutter/ephemeral/.symlinks/plugins/flutter_gemma/macos"
APP_BUNDLE="${BUILT_PRODUCTS_DIR}/${PRODUCT_NAME}.app"
RESOURCES_DIR="$APP_BUNDLE/Contents/Resources"
JAR_NAME="litertlm-server.jar"
JAR_CACHE_DIR="$HOME/Library/Caches/flutter_gemma/jar"
JAR_CACHE_PATH="$JAR_CACHE_DIR/$JAR_NAME"
JAR_URL="https://github.com/DenisovAV/flutter_gemma/releases/download/v0.12.6/$JAR_NAME"
JAR_CHECKSUM="fefc53d076533de164b5ce07c65f9aedc4739f83efc93e67625f0d90029ae5b7"

mkdir -p "$RESOURCES_DIR" "$JAR_CACHE_DIR"
if [ ! -f "$RESOURCES_DIR/$JAR_NAME" ]; then
  if [ ! -f "$JAR_CACHE_PATH" ]; then
    TMP_JAR_PATH="$JAR_CACHE_PATH.tmp"
    rm -f "$TMP_JAR_PATH"
    curl -L --fail --retry 3 --progress-bar -o "$TMP_JAR_PATH" "$JAR_URL"
    echo "$JAR_CHECKSUM  $TMP_JAR_PATH" | shasum -a 256 -c -
    mv "$TMP_JAR_PATH" "$JAR_CACHE_PATH"
  fi
  cp "$JAR_CACHE_PATH" "$RESOURCES_DIR/$JAR_NAME"
fi

if [ -f "$PLUGIN_PATH/scripts/setup_desktop.sh" ]; then
  sh "$PLUGIN_PATH/scripts/setup_desktop.sh" "$PLUGIN_PATH" "$APP_BUNDLE"
fi
SCRIPT
    main_project.save
  end
end
